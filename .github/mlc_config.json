{
  "aliveStatusCodes": [200, 206],
  "ignorePatterns": [
    {
      "pattern": "^https://opencode\\.ai"
    },
    {
      "pattern": "^https://www\\.redotpay\\.com"
    }
  ],
  "replacementPatterns": [
    {
      "pattern": "^/",
      "replacement": "{{BASEURL}}/"
    }
  ],
  "httpHeaders": [
    {
      "urls": ["https://github.com"],
      "headers": {
        "Accept": "text/html"
      }
    }
  ],
  "retryCount": 2,
  "retryOn429": true,
  "timeout": "20s",
  "fallbackOnStatus": [],
  "ignoreBaseUrl": false
}