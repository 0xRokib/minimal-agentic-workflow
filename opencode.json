{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".context/CONTEXT.md"
  ],
  "command": {
    "plan": {
      "description": "Create a detailed implementation plan",
      "template": "{file:.opencode/commands/plan.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    },
    "code-review": {
      "description": "Review docs and config for quality and consistency",
      "template": "{file:.opencode/commands/code-review.md}\n\n$ARGUMENTS",
      "agent": "code-reviewer",
      "subtask": true
    },
    "security": {
      "description": "Security review — check for exposed secrets or injection risks",
      "template": "{file:.opencode/commands/security.md}\n\n$ARGUMENTS",
      "agent": "security-reviewer",
      "subtask": true
    },
    "update-docs": {
      "description": "Update documentation to match current state",
      "template": "{file:.opencode/commands/update-docs.md}\n\n$ARGUMENTS",
      "agent": "doc-updater",
      "subtask": true
    },
    "learn": {
      "description": "Extract patterns and learnings from session",
      "template": "{file:.opencode/commands/learn.md}\n\n$ARGUMENTS"
    },
    "checkpoint": {
      "description": "Save progress snapshot",
      "template": "{file:.opencode/commands/checkpoint.md}\n\n$ARGUMENTS"
    },
    "verify": {
      "description": "Verify all links, paths, and markdown render correctly",
      "template": "{file:.opencode/commands/verify.md}\n\n$ARGUMENTS"
    }
  }
}
